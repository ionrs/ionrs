{
  "name": "ion-lang",
  "displayName": "Ion Language",
  "description": "Syntax highlighting and LSP support for the Ion scripting language",
  "version": "0.6.0",
  "publisher": "ionlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chutuananh2k/ion-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:ion"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ion",
        "aliases": ["Ion", "ion"],
        "extensions": [".ion"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ion",
        "scopeName": "source.ion",
        "path": "./syntaxes/ion.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Ion Language",
      "properties": {
        "ion.lsp.path": {
          "type": "string",
          "default": "ion-lsp",
          "description": "Path to the ion-lsp binary"
        },
        "ion.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Ion language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
