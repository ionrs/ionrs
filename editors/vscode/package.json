{
  "name": "ion-lang",
  "displayName": "Ion Language",
  "description": "Syntax highlighting and LSP support for the Ion scripting language",
  "version": "0.7.7",
  "publisher": "ionlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chutuananh2k/ion-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ion"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ion",
        "aliases": [
          "Ion",
          "ion"
        ],
        "extensions": [
          ".ion"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ion",
        "scopeName": "source.ion",
        "path": "./syntaxes/ion.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Ion Language",
      "properties": {
        "ion.lsp.path": {
          "type": "string",
          "default": "ion-lsp",
          "description": "Path to the ion-lsp binary. Can also be a quoted command line, for example: wsl ion-lsp"
        },
        "ion.lsp.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed to the ion-lsp command"
        },
        "ion.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Ion language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm install && npm run compile && npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
