{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ion",
  "scopeName": "source.ion",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#bytes" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#lambda" },
    { "include": "#dict-literal" },
    { "include": "#module-path" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ion",
          "match": "//.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.interpolated.ion",
          "begin": "f\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.triple.ion",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.double.interpolated.ion",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.double.ion",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },

    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.ion",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.ion" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.ion" }
          },
          "patterns": [
            { "include": "source.ion" }
          ]
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.ion",
          "match": "\\\\[nrt\\\\\"0]"
        },
        {
          "name": "constant.character.escape.hex.ion",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "constant.character.escape.unicode.ion",
          "match": "\\\\u\\{[0-9a-fA-F]+\\}"
        }
      ]
    },

    "bytes": {
      "patterns": [
        {
          "name": "string.quoted.byte.ion",
          "begin": "b\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ion",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.ion",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ion",
          "match": "\\b(if|else|while|for|loop|break|continue|return|match|in|async|spawn|select|try|catch|use)\\b"
        },
        {
          "name": "keyword.declaration.ion",
          "match": "\\b(let|mut|fn)\\b"
        },
        {
          "name": "keyword.operator.ion",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.ion",
          "match": "\\b(Some|None|Ok|Err)\\b"
        },
        {
          "match": ":\\s*(int|float|bool|string|bytes|list|dict|tuple|set|fn|any|Option|Result)\\b",
          "captures": {
            "1": { "name": "support.type.annotation.ion" }
          }
        },
        {
          "name": "support.type.annotation.ion",
          "match": "(?<=<)(int|float|bool|string|bytes|list|dict|tuple|set|fn|any|Option|Result)(?=[>,])"
        }
      ]
    },

    "builtins": {
      "patterns": [
        {
          "name": "support.function.ion",
          "match": "\\b(len|range|enumerate|type_of|str|int|float|bytes|bytes_from_hex|assert|assert_eq|channel|set|cell|sleep|timeout)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ion",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.unit.ion",
          "match": "\\(\\)"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.ion",
          "match": "\\.\\.\\.|\\.\\.|\\.\\.="
        },
        {
          "name": "keyword.operator.arrow.ion",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipe.ion",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.try.ion",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.comparison.ion",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ion",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.ion",
          "match": "\\+=|-=|\\*=|/=|="
        },
        {
          "name": "keyword.operator.arithmetic.ion",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.ion",
          "match": "<<|>>|&|\\||\\^"
        }
      ]
    },

    "function-def": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.ion" },
            "2": { "name": "entity.name.function.ion" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.ion" }
          }
        },
        {
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.method.ion" }
          }
        }
      ]
    },

    "lambda": {
      "patterns": [
        {
          "match": "\\|([^|]*)\\|",
          "captures": {
            "0": { "name": "meta.lambda.ion" }
          }
        }
      ]
    },

    "dict-literal": {
      "patterns": [
        {
          "name": "punctuation.definition.dict.ion",
          "match": "#\\{"
        }
      ]
    },

    "module-path": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.ion" },
            "2": { "name": "punctuation.separator.namespace.ion" },
            "3": { "name": "entity.name.other.ion" }
          }
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.namespace.ion",
          "match": "::"
        },
        {
          "name": "punctuation.separator.ion",
          "match": "[;,]"
        },
        {
          "name": "punctuation.accessor.ion",
          "match": "\\."
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ion",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
